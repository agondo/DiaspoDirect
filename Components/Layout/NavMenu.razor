@implements IDisposable

@inject NavigationManager NavigationManager

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href=""><img src="/images/logo/dd_logo.png" alt="DiaspoDirect" style="height:36px; background:white; border-radius:7px; padding:3px 7px;" /></a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        <AuthorizeView>
            <Authorized>
                <AuthorizeView Roles="Admin">
                    <Authorized Context="adminCtx">
                        <div class="nav-item px-3">
                            <NavLink class="nav-link" href="admin">
                                <span class="bi bi-speedometer2-nav-menu" aria-hidden="true"></span> Admin Dashboard
                            </NavLink>
                        </div>
                        <div class="nav-item px-3">
                            <NavLink class="nav-link" href="admin/exchange-rates">
                                <span class="bi bi-currency-exchange-nav-menu" aria-hidden="true"></span> Exchange Rates
                            </NavLink>
                        </div>
                        <div class="nav-item px-3">
                            <NavLink class="nav-link" href="admin/providers">
                                <span class="bi bi-building-nav-menu" aria-hidden="true"></span> Providers
                            </NavLink>
                        </div>
                        <div class="nav-item px-3">
                            <NavLink class="nav-link" href="admin/provider-payments">
                                <span class="bi bi-cash-coin-nav-menu" aria-hidden="true"></span> Provider Payments
                            </NavLink>
                        </div>
                    </Authorized>
                    <NotAuthorized Context="nonAdminCtx">
                        <div class="nav-item px-3">
                            <NavLink class="nav-link" href="dashboard">
                                <span class="bi bi-grid-fill-nav-menu" aria-hidden="true"></span> Dashboard
                            </NavLink>
                        </div>
                    </NotAuthorized>
                </AuthorizeView>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="pharmacies">
                        <span class="bi bi-capsule-nav-menu" aria-hidden="true"></span> Pharmacies
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="my-prescriptions">
                        <span class="bi bi-file-earmark-medical-nav-menu" aria-hidden="true"></span> My Prescriptions
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="send-prescriptions">
                        <span class="bi bi-send-nav-menu" aria-hidden="true"></span> Send Prescription
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="payment-history">
                        <span class="bi bi-clock-history-nav-menu" aria-hidden="true"></span> Payment History
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="Account/Manage">
                        <span class="bi bi-person-fill-nav-menu" aria-hidden="true"></span> @context.User.Identity?.Name
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <form @formname="logout" action="Account/Logout" method="post">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                        <button type="submit" class="nav-link">
                            <span class="bi bi-arrow-bar-left-nav-menu" aria-hidden="true"></span> Logout
                        </button>
                    </form>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="Account/Register">
                        <span class="bi bi-person-nav-menu" aria-hidden="true"></span> Register
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="Account/Login">
                        <span class="bi bi-person-badge-nav-menu" aria-hidden="true"></span> Login
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}

@page "/dashboard"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using DiaspoDirect.Data
@attribute [Authorize]
@rendermode InteractiveServer

@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider
@inject ApplicationDbContext Db

<PageTitle>My Dashboard</PageTitle>

<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0">My Dashboard</h2>
            <p class="text-muted mb-0">Welcome back, <strong>@displayName</strong></p>
        </div>
        <span class="badge bg-primary fs-6 px-3 py-2">Member</span>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-sm-6 col-lg-3">
            <a href="my-prescriptions" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 stat-card">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="rounded-circle bg-info bg-opacity-10 p-3">
                            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="#0dcaf0" viewBox="0 0 16 16">
                                <path d="M5 4a.5.5 0 0 0 0 1h6a.5.5 0 0 0 0-1H5zm-.5 2.5A.5.5 0 0 1 5 6h6a.5.5 0 0 1 0 1H5a.5.5 0 0 1-.5-.5zM5 8a.5.5 0 0 0 0 1h6a.5.5 0 0 0 0-1H5zm0 2a.5.5 0 0 0 0 1h3a.5.5 0 0 0 0-1H5z"/>
                                <path d="M2 2a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2zm10-1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1z"/>
                            </svg>
                        </div>
                        <div>
                            <p class="text-muted small mb-0">My Prescriptions</p>
                            <h3 class="mb-0 fw-bold">@myPrescriptionsCount</h3>
                            @if (myPrescriptionsPending > 0)
                            {
                                <span class="badge bg-warning-subtle text-warning border border-warning-subtle small">@myPrescriptionsPending pending</span>
                            }
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-sm-6 col-lg-3">
            <a href="send-prescriptions" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 stat-card">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="rounded-circle bg-primary bg-opacity-10 p-3">
                            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="#1b6ec2" viewBox="0 0 16 16">
                                <path d="M15.854.146a.5.5 0 0 1 .11.54l-5.819 14.547a.75.75 0 0 1-1.329.124l-3.178-4.995L.643 7.184a.75.75 0 0 1 .124-1.33L15.314.037a.5.5 0 0 1 .54.11ZM6.636 10.07l2.761 4.338L14.13 2.576 6.636 10.07Zm6.787-8.201L1.591 6.602l4.339 2.76 7.494-7.493Z"/>
                            </svg>
                        </div>
                        <div>
                            <p class="text-muted small mb-0">Send Prescriptions</p>
                            <h3 class="mb-0 fw-bold">@sendPrescriptionsCount</h3>
                            @if (sendPrescriptionsPending > 0)
                            {
                                <span class="badge bg-warning-subtle text-warning border border-warning-subtle small">@sendPrescriptionsPending pending</span>
                            }
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-sm-6 col-lg-3">
            <a href="pharmacies" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 stat-card">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="rounded-circle bg-success bg-opacity-10 p-3">
                            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="#198754" viewBox="0 0 16 16">
                                <path d="M11 6.5a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5v-1zm-3 0a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5v-1zm-5 3a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5v-1zm3 0a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5v-1z"/>
                                <path d="M2 1.5a.5.5 0 0 1 .5-.5h11a.5.5 0 0 1 .5.5V5h.5a.5.5 0 0 1 0 1H14v1.5h.5a.5.5 0 0 1 0 1H14V15h.5a.5.5 0 0 1 0 1H1.5a.5.5 0 0 1 0-1H2V8.5h-.5a.5.5 0 0 1 0-1H2V6h-.5a.5.5 0 0 1 0-1H2V1.5zM3 6v2.5h10V6H3zm10 3.5H3V15h4v-3a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v3h4V9.5zM13 5V2H3v3h10z"/>
                            </svg>
                        </div>
                        <div>
                            <p class="text-muted small mb-0">Pharmacies</p>
                            <h3 class="mb-0 fw-bold">@totalPharmacies</h3>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-sm-6 col-lg-3">
            <a href="Account/Manage" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 stat-card">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="rounded-circle bg-success bg-opacity-10 p-3">
                            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="#198754" viewBox="0 0 16 16">
                                <path d="M3 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1H3Zm5-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z"/>
                            </svg>
                        </div>
                        <div>
                            <p class="text-muted small mb-0">Account Status</p>
                            <h6 class="mb-0 fw-bold text-success">Active</h6>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-sm-6 col-lg-3">
            <a href="Account/Manage/Email" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 stat-card">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="rounded-circle bg-opacity-10 p-3 @(emailConfirmed ? "bg-success" : "bg-warning")">
                            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="@(emailConfirmed ? "#198754" : "#ffc107")" viewBox="0 0 16 16">
                                <path d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V4Zm2-1a1 1 0 0 0-1 1v.217l7 4.2 7-4.2V4a1 1 0 0 0-1-1H2Zm13 2.383-4.708 2.825L15 11.105V5.383Zm-.034 6.876-5.64-3.471L8 9.583l-1.326-.795-5.64 3.47A1 1 0 0 0 2 13h12a1 1 0 0 0 .966-.741ZM1 11.105l4.708-2.897L1 5.383v5.722Z"/>
                            </svg>
                        </div>
                        <div>
                            <p class="text-muted small mb-0">Email</p>
                            <h6 class="mb-0 fw-bold @(emailConfirmed ? "text-success" : "text-warning")">
                                @(emailConfirmed ? "Confirmed" : "Pending")
                            </h6>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="mb-0 fw-semibold">Account Information</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-5 text-muted fw-normal">First Name</dt>
                        <dd class="col-7 fw-semibold">@(firstName ?? "—")</dd>

                        <dt class="col-5 text-muted fw-normal">Last Name</dt>
                        <dd class="col-7 fw-semibold">@(lastName ?? "—")</dd>

                        <dt class="col-5 text-muted fw-normal">Email Address</dt>
                        <dd class="col-7 fw-semibold">@userEmail</dd>

                        <dt class="col-5 text-muted fw-normal">Phone Number</dt>
                        <dd class="col-7">@(phoneNumber ?? "—")</dd>

                        <dt class="col-5 text-muted fw-normal">Email Confirmed</dt>
                        <dd class="col-7">
                            @if (emailConfirmed)
                            {
                                <span class="badge bg-success-subtle text-success border border-success-subtle">Yes</span>
                            }
                            else
                            {
                                <span class="badge bg-warning-subtle text-warning border border-warning-subtle">Pending</span>
                            }
                        </dd>

                        <dt class="col-5 text-muted fw-normal">Two-Factor Auth</dt>
                        <dd class="col-7">
                            @if (twoFactorEnabled)
                            {
                                <span class="badge bg-success-subtle text-success border border-success-subtle">Enabled</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle">Disabled</span>
                            }
                        </dd>
                    </dl>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="mb-0 fw-semibold">Quick Links</h5>
                </div>
                <div class="card-body d-grid gap-2">
                    <a href="my-prescriptions" class="btn btn-primary">My Prescriptions</a>
                    <a href="send-prescriptions" class="btn btn-outline-primary">Send Prescription</a>
                    <a href="pharmacies" class="btn btn-outline-secondary">Pharmacies</a>
                    <a href="Account/Manage" class="btn btn-outline-secondary">Edit Profile</a>
                    <a href="Account/Manage/ChangePassword" class="btn btn-outline-secondary">Change Password</a>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string userEmail = "";
    private string? firstName;
    private string? lastName;
    private string? phoneNumber;
    private string displayName = "";
    private bool emailConfirmed;
    private bool twoFactorEnabled;
    private int myPrescriptionsCount;
    private int myPrescriptionsPending;
    private int sendPrescriptionsCount;
    private int sendPrescriptionsPending;
    private int totalPharmacies;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        userEmail = auth.User.Identity?.Name ?? "";
        if (string.IsNullOrEmpty(userEmail)) return;

        var user = await UserManager.FindByNameAsync(userEmail);
        if (user is null) return;

        firstName        = user.FirstName;
        lastName         = user.LastName;
        phoneNumber      = user.PhoneNumber;
        emailConfirmed   = user.EmailConfirmed;
        twoFactorEnabled = user.TwoFactorEnabled;
        displayName      = !string.IsNullOrWhiteSpace(user.FirstName)
                           ? $"{user.FirstName} {user.LastName}".Trim()
                           : userEmail;

        myPrescriptionsCount   = await Db.MyPrescriptions.CountAsync(r => r.UserId == user.Id);
        myPrescriptionsPending = await Db.MyPrescriptions.CountAsync(r => r.UserId == user.Id && r.Status == "Pending");
        sendPrescriptionsCount   = await Db.SendPrescriptions.CountAsync(r => r.UserId == user.Id);
        sendPrescriptionsPending = await Db.SendPrescriptions.CountAsync(r => r.UserId == user.Id && r.Status == "Pending");
        totalPharmacies          = await Db.Pharmacies.CountAsync();
    }
}

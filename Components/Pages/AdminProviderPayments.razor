@page "/admin/provider-payments"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using DiaspoDirect.Data
@using System.Security.Claims
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer

@inject ApplicationDbContext Db
@inject AuthenticationStateProvider AuthState
@inject DiaspoDirect.Services.NotificationService Notifications

<PageTitle>Provider Payments — Admin</PageTitle>

<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a href="/admin">Admin</a></li>
                    <li class="breadcrumb-item active">Provider Payments</li>
                </ol>
            </nav>
            <h2 class="mb-0">Provider Payments</h2>
            <p class="text-muted mb-0">Track and mark payments sent to providers</p>
        </div>
    </div>

    @if (successMessage is not null)
    {
        <div class="alert alert-success alert-dismissible mb-4" role="alert">
            @successMessage
            <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
        </div>
    }
    @if (errorMessage is not null)
    {
        <div class="alert alert-danger alert-dismissible mb-4" role="alert">
            @errorMessage
            <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
        </div>
    }

    <!-- Summary stats -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-primary bg-opacity-10 p-3">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="#1b6ec2" viewBox="0 0 16 16">
                            <path d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V4zm2-1a1 1 0 0 0-1 1v.217l7 4.2 7-4.2V4a1 1 0 0 0-1-1H2zm13 2.383-4.708 2.825L15 11.105V5.383zm-.034 6.876-5.64-3.471L8 9.583l-1.326-.795-5.64 3.47A1 1 0 0 0 2 13h12a1 1 0 0 0 .966-.741zM1 11.105l4.708-2.897L1 5.383v5.722z"/>
                        </svg>
                    </div>
                    <div>
                        <p class="text-muted small mb-0">Total Payments</p>
                        <h3 class="mb-0 fw-bold">@rows.Count</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-secondary bg-opacity-10 p-3">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="#6c757d" viewBox="0 0 16 16">
                            <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                            <path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0zM7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 4.995z"/>
                        </svg>
                    </div>
                    <div>
                        <p class="text-muted small mb-0">No Provider</p>
                        <h3 class="mb-0 fw-bold text-secondary">@rows.Count(r => r.ProviderPaymentId is null)</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-warning bg-opacity-10 p-3">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="#ffc107" viewBox="0 0 16 16">
                            <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm.93-9.412-1 4.705c-.07.34.029.533.304.533.194 0 .487-.07.686-.246l-.088.416c-.287.346-.92.598-1.465.598-.703 0-1.002-.422-.808-1.319l.738-3.468c.064-.293.006-.399-.287-.47l-.451-.081.082-.381 2.29-.287zM8 5.5a1 1 0 1 1 0-2 1 1 0 0 1 0 2z"/>
                        </svg>
                    </div>
                    <div>
                        <p class="text-muted small mb-0">Awaiting Payment</p>
                        <h3 class="mb-0 fw-bold text-warning">@rows.Count(r => r.ProviderStatus == ProviderPaymentStatus.Assigned || r.ProviderStatus == ProviderPaymentStatus.Pending)</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-success bg-opacity-10 p-3">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="#198754" viewBox="0 0 16 16">
                            <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                        </svg>
                    </div>
                    <div>
                        <p class="text-muted small mb-0">Paid to Provider</p>
                        <h3 class="mb-0 fw-bold text-success">@rows.Count(r => r.ProviderStatus == ProviderPaymentStatus.Paid)</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Filter bar -->
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body py-2 d-flex align-items-center gap-2 flex-wrap">
            <span class="text-muted small fw-semibold me-1">Show:</span>
            <button class="btn btn-sm @(filter == "all"     ? "btn-primary"          : "btn-outline-secondary")" @onclick='() => filter = "all"'>All (@rows.Count)</button>
            <button class="btn btn-sm @(filter == "pending" ? "btn-warning"          : "btn-outline-secondary")" @onclick='() => filter = "pending"'>Unpaid (@rows.Count(r => r.ProviderStatus != ProviderPaymentStatus.Paid))</button>
            <button class="btn btn-sm @(filter == "paid"    ? "btn-success"          : "btn-outline-secondary")" @onclick='() => filter = "paid"'>Paid to Provider (@rows.Count(r => r.ProviderStatus == ProviderPaymentStatus.Paid))</button>
        </div>
    </div>

    <!-- Table -->
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            @{
                var filtered = filter switch
                {
                    "pending" => rows.Where(r => r.ProviderStatus != ProviderPaymentStatus.Paid).ToList(),
                    "paid"    => rows.Where(r => r.ProviderStatus == ProviderPaymentStatus.Paid).ToList(),
                    _         => rows
                };
            }
            @if (filtered.Count == 0)
            {
                <div class="text-center text-muted py-5">
                    <div style="font-size:2rem">💊</div>
                    <p class="mt-2 mb-0">No payments found.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">Prescription</th>
                                <th>Recipient</th>
                                <th>Provider</th>
                                <th class="text-end">Amount XOF</th>
                                <th class="text-end">Amount USD</th>
                                <th class="text-center">Status</th>
                                <th class="text-center pe-3">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in filtered)
                            {
                                <tr>
                                    <td class="ps-3">
                                        <div class="fw-semibold small text-truncate" style="max-width:180px" title="@r.PrescriptionFileName">
                                            @r.PrescriptionFileName
                                        </div>
                                        <div class="text-muted" style="font-size:0.72rem">@r.CreatedAt.ToString("MMM dd, yyyy")</div>
                                    </td>
                                    <td>
                                        <div>@(r.RecipientName ?? "—")</div>
                                        <div class="text-muted small">@r.CountryName</div>
                                    </td>
                                    <td>
                                        @if (r.ProviderName is not null)
                                        {
                                            <div class="small fw-semibold">@r.ProviderName</div>
                                            <button class="btn btn-link btn-sm p-0 text-muted" style="font-size:0.72rem"
                                                    @onclick="() => OpenAssign(r)">Change</button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-outline-primary btn-sm" @onclick="() => OpenAssign(r)">Assign</button>
                                        }
                                    </td>
                                    <td class="text-end small">@r.AmountCFA.ToString("N0") XOF</td>
                                    <td class="text-end small fw-semibold">$@r.AmountUsd.ToString("N2")</td>
                                    <td class="text-center">
                                        @if (r.ProviderPaymentId is null)
                                        {
                                            <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle">No Provider</span>
                                        }
                                        else if (r.ProviderStatus == ProviderPaymentStatus.Paid)
                                        {
                                            <span class="badge bg-success-subtle text-success border border-success-subtle">Paid to Provider</span>
                                            @if (r.PaidAt.HasValue)
                                            {
                                                <div class="text-muted" style="font-size:0.7rem">@r.PaidAt.Value.ToString("MMM dd, yyyy")</div>
                                            }
                                        }
                                        else if (r.ProviderStatus == ProviderPaymentStatus.Failed)
                                        {
                                            <span class="badge bg-danger-subtle text-danger border border-danger-subtle">Failed</span>
                                        }
                                        else if (r.ProviderStatus == ProviderPaymentStatus.Cancelled)
                                        {
                                            <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle">Cancelled</span>
                                        }
                                        else if (r.ProviderStatus == ProviderPaymentStatus.Assigned)
                                        {
                                            <span class="badge bg-info-subtle text-info border border-info-subtle">Assigned</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning-subtle text-warning border border-warning-subtle">Pending Transfer</span>
                                        }
                                    </td>
                                    <td class="text-center pe-3">
                                        @if (r.ProviderPaymentId is null)
                                        {
                                            <span class="text-muted small">Assign provider first</span>
                                        }
                                        else if (r.ProviderStatus != ProviderPaymentStatus.Paid)
                                        {
                                            <button class="btn btn-sm btn-success" @onclick="() => OpenMarkPaid(r)">Mark Paid</button>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">@(r.ReferenceNumber ?? "—")</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="px-3 py-2 text-muted small border-top">
                    Showing @filtered.Count of @rows.Count payments
                </div>
            }
        </div>
    </div>
</div>

<!-- Mark Paid slide panel -->
@if (markPaidRow is not null)
{
    <div class="modal-backdrop-custom" @onclick="ClosePanel"></div>
    <div class="modal-panel-custom">
        <div class="modal-panel-header">
            <h5 class="mb-0">Mark as Paid to Provider</h5>
            <button class="btn-close" @onclick="ClosePanel"></button>
        </div>
        <div class="modal-panel-body">
            <div class="mb-3 p-3 bg-light rounded">
                <div class="small text-muted mb-1">Prescription</div>
                <div class="fw-semibold">@markPaidRow.PrescriptionFileName</div>
                <div class="small text-muted mt-2 mb-1">Recipient</div>
                <div>@(markPaidRow.RecipientName ?? "—") — @markPaidRow.CountryName</div>
                <div class="small text-muted mt-2 mb-1">Provider</div>
                <div class="fw-semibold">@markPaidRow.ProviderName</div>
                <div class="small text-muted mt-2 mb-1">Amount</div>
                <div class="fw-semibold">@markPaidRow.AmountCFA.ToString("N0") XOF / $@markPaidRow.AmountUsd.ToString("N2")</div>
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Payment Method <span class="text-danger">*</span></label>
                <select class="form-select" @bind="markPaidMethod">
                    @foreach (var method in Enum.GetValues<ProviderPaymentMethod>())
                    {
                        <option value="@method">@method</option>
                    }
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Reference Number
                    <span class="text-muted fw-normal">(optional)</span>
                </label>
                <input class="form-control" placeholder="e.g. WAVE-123456 or bank transfer ref"
                       @bind="markPaidReference" />
                <div class="form-text">Mobile money confirmation code, bank ref, or any tracking number.</div>
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Receipt URL
                    <span class="text-muted fw-normal">(optional)</span>
                </label>
                <input class="form-control" placeholder="https://..." @bind="markPaidReceiptUrl" />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Notes
                    <span class="text-muted fw-normal">(optional)</span>
                </label>
                <textarea class="form-control" rows="3" placeholder="Admin notes or audit details..." @bind="markPaidNotes"></textarea>
            </div>
        </div>
        <div class="modal-panel-footer">
            <button class="btn btn-outline-secondary" @onclick="ClosePanel">Cancel</button>
            <button class="btn btn-success" @onclick="ConfirmMarkPaid" disabled="@isSaving">
                @if (isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                Confirm Paid
            </button>
        </div>
    </div>
}

<!-- Assign Provider slide panel -->
@if (assignRow is not null)
{
    <div class="modal-backdrop-custom" @onclick="CloseAssign"></div>
    <div class="modal-panel-custom">
        <div class="modal-panel-header">
            <h5 class="mb-0">Assign Provider</h5>
            <button class="btn-close" @onclick="CloseAssign"></button>
        </div>
        <div class="modal-panel-body">
            <div class="mb-3 p-3 bg-light rounded">
                <div class="small text-muted mb-1">Prescription</div>
                <div class="fw-semibold">@assignRow.PrescriptionFileName</div>
                <div class="small text-muted mt-2 mb-1">Recipient</div>
                <div>@(assignRow.RecipientName ?? "—") — @assignRow.CountryName</div>
            </div>

            @if (assignFormError is not null)
            {
                <div class="alert alert-danger py-2 small">@assignFormError</div>
            }

            <div class="mb-3">
                <label class="form-label fw-semibold">Provider <span class="text-danger">*</span></label>
                <select class="form-select" @bind="assignProviderId">
                    <option value="">— Select a provider —</option>
                    @foreach (var p in providers)
                    {
                        <option value="@p.ProviderId">@p.ProviderName (@p.ProviderType)</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Amount XOF</label>
                <input class="form-control" type="number" @bind="assignAmountXOF" />
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Payment Method <span class="text-muted fw-normal">(optional)</span></label>
                <select class="form-select" @bind="assignPaymentMethod">
                    @foreach (var method in Enum.GetValues<ProviderPaymentMethod>())
                    {
                        <option value="@method">@method</option>
                    }
                </select>
            </div>
        </div>
        <div class="modal-panel-footer">
            <button class="btn btn-outline-secondary" @onclick="CloseAssign">Cancel</button>
            <button class="btn btn-primary" @onclick="SaveAssignProvider" disabled="@isSaving">
                @if (isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                Save
            </button>
        </div>
    </div>
}

<style>
    .modal-backdrop-custom {
        position: fixed; inset: 0;
        background: rgba(0,0,0,0.4);
        z-index: 1040;
    }
    .modal-panel-custom {
        position: fixed; top: 0; right: 0; bottom: 0;
        width: 440px; max-width: 100%;
        background: #fff;
        z-index: 1050;
        display: flex; flex-direction: column;
        box-shadow: -4px 0 24px rgba(0,0,0,0.12);
    }
    .modal-panel-header {
        display: flex; justify-content: space-between; align-items: center;
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid #e5e7eb;
        font-weight: 600;
    }
    .modal-panel-body {
        flex: 1; overflow-y: auto;
        padding: 1.5rem;
    }
    .modal-panel-footer {
        padding: 1rem 1.5rem;
        border-top: 1px solid #e5e7eb;
        display: flex; justify-content: flex-end; gap: 0.5rem;
    }
</style>

@code {
    private List<PaymentRow> rows = [];
    private List<Provider> providers = [];
    private string filter = "pending";
    private string? successMessage;
    private string? errorMessage;

    private PaymentRow? markPaidRow;
    private ProviderPaymentMethod markPaidMethod = ProviderPaymentMethod.Wave;
    private string? markPaidReference;
    private string? markPaidReceiptUrl;
    private string? markPaidNotes;

    private PaymentRow? assignRow;
    private Guid assignProviderId;
    private decimal assignAmountXOF;
    private ProviderPaymentMethod assignPaymentMethod = ProviderPaymentMethod.Wave;
    private string? assignFormError;

    private bool isSaving;

    protected override async Task OnInitializedAsync()
    {
        providers = await Db.Providers.Where(p => p.IsActive).OrderBy(p => p.ProviderName).ToListAsync();
        await LoadRows();
    }

    private async Task LoadRows()
    {
        var payments = await Db.Payments
            .Where(p => p.Status == "Paid")
            .Include(p => p.Prescription)
            .OrderByDescending(p => p.CreatedAt)
            .ToListAsync();

        var paymentIds = payments.Select(p => p.Id).Distinct().ToList();

        var providerMap = await Db.ProviderPayments
            .Where(pp => paymentIds.Contains(pp.PaymentId))
            .Include(pp => pp.Provider)
            .GroupBy(pp => pp.PaymentId)
            .ToDictionaryAsync(g => g.Key, g =>
            {
                var first = g.First();
                return (first.Id, first.Provider.ProviderName, first.Status, first.PaidAt, first.ReferenceNumber);
            });

        rows = payments.Select(p =>
        {
            providerMap.TryGetValue(p.Id, out var prov);
            return new PaymentRow(
                p.Id,
                p.PrescriptionId,
                p.Prescription.PrescriptionFileName,
                p.Prescription.RecipientFirstLastName,
                p.Prescription.CountryName,
                prov == default ? null : (Guid?)prov.Id,
                prov == default ? null : prov.ProviderName,
                p.Prescription.AmountCFA,
                p.AmountUsd,
                prov == default ? null : (ProviderPaymentStatus?)prov.Status,
                prov == default ? null : prov.PaidAt,
                prov == default ? null : prov.ReferenceNumber,
                p.CreatedAt
            );
        }).ToList();
    }

    private void OpenMarkPaid(PaymentRow row)
    {
        markPaidRow = row;
        markPaidMethod = ProviderPaymentMethod.Wave;
        markPaidReference = null;
        markPaidReceiptUrl = null;
        markPaidNotes = null;
    }

    private void ClosePanel() => markPaidRow = null;

    private void OpenAssign(PaymentRow row)
    {
        assignRow = row;
        assignProviderId = Guid.Empty;
        assignAmountXOF = row.AmountCFA;
        assignPaymentMethod = ProviderPaymentMethod.Wave;
        assignFormError = null;
    }

    private void CloseAssign() => assignRow = null;

    private async Task SaveAssignProvider()
    {
        if (assignRow is null) return;
        if (assignProviderId == Guid.Empty) { assignFormError = "Please select a provider."; return; }

        isSaving = true;
        assignFormError = null;
        try
        {
            if (assignRow.ProviderPaymentId.HasValue)
            {
                var existing = await Db.ProviderPayments.FindAsync(assignRow.ProviderPaymentId.Value);
                if (existing is not null) Db.ProviderPayments.Remove(existing);
            }

            var newProviderPayment = new ProviderPayment
            {
                ProviderId    = assignProviderId,
                PaymentId     = assignRow.Id,
                AmountXOF     = assignAmountXOF,
                PaymentMethod = assignPaymentMethod,
                Status        = ProviderPaymentStatus.Assigned
            };
            Db.ProviderPayments.Add(newProviderPayment);

            await Db.SaveChangesAsync();
            successMessage = "Provider assigned successfully.";
            errorMessage   = null;

            var provider    = await Db.Providers.FindAsync(assignProviderId);
            var prescription = await Db.SendPrescriptions.FindAsync(assignRow.PrescriptionId);
            if (provider is not null && prescription is not null)
                await Notifications.NotifyProviderAssignedAsync(provider, newProviderPayment, prescription);

            assignRow = null;
            await LoadRows();
        }
        catch (Exception ex)
        {
            assignFormError = $"Error: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task ConfirmMarkPaid()
    {
        if (markPaidRow is null) return;
        if (!markPaidRow.ProviderPaymentId.HasValue)
        {
            errorMessage = "Assign a provider before marking as paid.";
            markPaidRow  = null;
            return;
        }

        isSaving = true;
        try
        {
            var pp = await Db.ProviderPayments.FindAsync(markPaidRow.ProviderPaymentId.Value);
            if (pp is null) { errorMessage = "Provider payment record not found."; return; }

            var authState = await AuthState.GetAuthenticationStateAsync();
            var userId    = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

            pp.Status          = ProviderPaymentStatus.Paid;
            pp.PaymentMethod   = markPaidMethod;
            pp.ReferenceNumber = string.IsNullOrWhiteSpace(markPaidReference) ? null : markPaidReference.Trim();
            pp.ReceiptUrl      = string.IsNullOrWhiteSpace(markPaidReceiptUrl) ? null : markPaidReceiptUrl.Trim();
            pp.Notes           = string.IsNullOrWhiteSpace(markPaidNotes) ? null : markPaidNotes.Trim();
            pp.PaidByUserId    = userId;
            pp.PaidAt          = DateTime.UtcNow;
            pp.UpdatedAt       = DateTime.UtcNow;

            await Db.SaveChangesAsync();
            successMessage = "Payment marked as paid to provider.";
            errorMessage   = null;

            var provider     = await Db.Providers.FindAsync(pp.ProviderId);
            var payment      = await Db.Payments.Include(p => p.Prescription).FirstOrDefaultAsync(p => p.Id == pp.PaymentId);
            var customer     = payment is not null ? await Db.Users.FindAsync(payment.UserId) : null;
            if (provider is not null && payment is not null && customer?.Email is not null)
                await Notifications.NotifyProviderPaidAsync(
                    provider, pp, payment.Prescription,
                    customer.Email,
                    $"{customer.FirstName} {customer.LastName}".Trim());

            markPaidRow = null;
            await LoadRows();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private sealed record PaymentRow(
        Guid Id,
        Guid PrescriptionId,
        string PrescriptionFileName,
        string? RecipientName,
        string CountryName,
        Guid? ProviderPaymentId,
        string? ProviderName,
        decimal AmountCFA,
        decimal AmountUsd,
        ProviderPaymentStatus? ProviderStatus,
        DateTime? PaidAt,
        string? ReferenceNumber,
        DateTime CreatedAt
    );
}

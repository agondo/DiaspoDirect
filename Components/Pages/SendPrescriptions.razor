    private async Task SendNewPrescriptionEmails(SendPrescription rx, string userEmail)
    {
        try
        {
            var userBody =
                $"<p>Hi {rx.FirstName},</p>" +
                "<p>We've received your prescription request. Here's a summary:</p>" +
                "<table cellpadding=\"6\" style=\"border-collapse:collapse;\">" +
                $"<tr><td><strong>Country:</strong></td><td>{rx.CountryName}</td></tr>" +
                $"<tr><td><strong>Amount (CFA):</strong></td><td>{rx.AmountCFA:N0} CFA</td></tr>" +
                $"<tr><td><strong>Amount (USD):</strong></td><td>{rx.AmountUSD:N2} USD</td></tr>" +
                "<tr><td><strong>Status:</strong></td><td>Pending</td></tr>" +
                $"<tr><td><strong>Submitted:</strong></td><td>{rx.CreatedDate:yyyy-MM-dd HH:mm} UTC</td></tr>" +
                "</table>" +
                "<p>We'll notify you as your prescription status changes.</p>" +
                "<p>&#8212; The DiaspoDirect Team</p>";

            await EmailSender.SendEmailAsync(userEmail,
                "Your prescription request has been received - DiaspoDirect",
                userBody);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to send prescription confirmation email to {Email}", userEmail);
        }

        try
        {
            var adminAddress = Config["Email:AdminAddress"] ?? "ceo@flaubertgroup.com";
            var adminBody =
                "<p>A new prescription request has been submitted on DiaspoDirect.</p>" +
                "<table cellpadding=\"6\" style=\"border-collapse:collapse;\">" +
                $"<tr><td><strong>Name:</strong></td><td>{rx.FirstName} {rx.LastName}</td></tr>" +
                $"<tr><td><strong>Phone:</strong></td><td>{rx.PhoneNumber}</td></tr>" +
                $"<tr><td><strong>Country:</strong></td><td>{rx.CountryName}</td></tr>" +
                $"<tr><td><strong>Recipient:</strong></td><td>{rx.RecipientFirstLastName ?? "n/a"}</td></tr>" +
                $"<tr><td><strong>Amount (CFA):</strong></td><td>{rx.AmountCFA:N0} CFA</td></tr>" +
                $"<tr><td><strong>Amount (USD):</strong></td><td>{rx.AmountUSD:N2} USD</td></tr>" +
                $"<tr><td><strong>Submitted:</strong></td><td>{rx.CreatedDate:yyyy-MM-dd HH:mm} UTC</td></tr>" +
                "</table>" +
                "<p><a href=\"/send-prescriptions\">Review on DiaspoDirect</a></p>";

            await EmailSender.SendEmailAsync(adminAddress,
                $"New prescription request - {rx.FirstName} {rx.LastName}",
                adminBody);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to send admin prescription notification email");
        }
    }

    private async Task SendStatusUpdateEmail(string toEmail, string firstName, SendPrescription rx)
    {
        try
        {
            var notesRow = string.IsNullOrWhiteSpace(rx.Notes)
                ? ""
                : $"<tr><td><strong>Notes:</strong></td><td>{rx.Notes}</td></tr>";

            var body =
                $"<p>Hi {firstName},</p>" +
                "<p>Your prescription request status has been updated.</p>" +
                "<table cellpadding=\"6\" style=\"border-collapse:collapse;\">" +
                $"<tr><td><strong>New Status:</strong></td><td>{rx.Status}</td></tr>" +
                $"<tr><td><strong>Country:</strong></td><td>{rx.CountryName}</td></tr>" +
                $"<tr><td><strong>Amount (CFA):</strong></td><td>{rx.AmountCFA:N0} CFA</td></tr>" +
                notesRow +
                "</table>" +
                "<p>Log in to <a href=\"https://diaspodirect.com/send-prescriptions\">DiaspoDirect</a> to view full details.</p>" +
                "<p>&#8212; The DiaspoDirect Team</p>";

            await EmailSender.SendEmailAsync(toEmail,
                $"Your prescription status has been updated - {rx.Status}",
                body);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to send status update email to {Email}", toEmail);
        }
    }

                </p>
                <div class="who-tagline">DiaspoDirect — A Service of Flaubert Group LLC, an IT Consulting and Fintech Firm. Connecting Families. Supporting Communities.</div>
            </div>
            <div class="who-pillars">
                <div class="pillar">
                    <div class="pillar-icon">🏛️</div>
                    <h4>US-Based Company</h4>
                    <p>Registered and operating in the United States, with full U.S. business standards, accountability, and compliance.</p>
                </div>
                <div class="pillar">
                    <div class="pillar-icon">🔒</div>
                    <h4>Secure Fintech Solutions</h4>
                    <p>Enterprise-grade security standards — every transaction encrypted, tracked, and auditable end to end.</p>
                </div>
                <div class="pillar">
                    <div class="pillar-icon"><svg class="ci-flag ci-flag-lg" viewBox="0 0 3 2" aria-label="Côte d'Ivoire"><rect width="1" height="2" fill="#F77F00"/><rect x="1" width="1" height="2" fill="#fff"/><rect x="2" width="1" height="2" fill="#009A44"/></svg></div>
                    <h4>Focused on Côte d'Ivoire</h4>
                    <p>Built specifically for the Ivorian diaspora, with trusted local partners on the ground in Côte d'Ivoire.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ── FAQ ─────────────────────────────────────────────────────────── -->
    <section class="faq-section" id="faq">
        <div class="section-header">
            <div class="section-tag">FAQ</div>
            <h2>Frequently Asked Questions</h2>
            <p class="section-subtitle">Everything you need to know before sending your first prescription.</p>
        </div>
        <div class="faq-list">
            @foreach (var item in faqs)
            {
                <details class="faq-item">
                    <summary class="faq-question">
                        <span>@item.Question</span>
                        <span class="faq-chevron">⌄</span>
                    </summary>
                    <div class="faq-answer-inner">
                        <p>@item.Answer</p>
                    </div>
                </details>
            }
        </div>
    </section>

    <!-- ── Bottom CTA ─────────────────────────────────────────────────── -->
    <section class="cta-section">
        <div class="cta-content">
            <h2>Ready to pay your family's pharmacy bill?</h2>
            <p>Join the Ivorian diaspora using DiaspoDirect. Send a prescription and we handle the rest — billing, payment, and pickup coordination.</p>
            <a href="/Account/Register" class="btn-primary-cta large">Send a Prescription</a>
            <div class="cta-trust">
                <span>✓ Free to register</span>
                <span>✓ Exact XOF billing — no surprises</span>
                <span>✓ Pay only when you send</span>
            </div>
        </div>
    </section>

    <!-- ── Footer ─────────────────────────────────────────────────────── -->
    <footer class="landing-footer">
        <div class="footer-inner">
            <div class="footer-brand">
                <strong>DiaspoDirect</strong>
                <span>Connecting the diaspora with their families.</span>
            </div>
            <div class="footer-links">
                <a href="#how-it-works">How It Works</a>
                <a href="#services">Services</a>
                <a href="#faq">FAQ</a>
                <a href="/Account/Login">Sign in</a>
                <a href="/Account/Register">Register</a>
            </div>
        </div>
        <div class="footer-copy">© 2026 DiaspoDirect, a service of Flaubert Group LLC. All rights reserved.</div>
    </footer>

</div>

@code {
    [SupplyParameterFromForm]
    private ContactModel contactModel { get; set; } = new();
    private bool contactSent;
    private bool contactError;
    private bool contactSubmitting;

    private async Task HandleContactSubmit()
    {
        contactSubmitting = true;
        contactSent = false;
        contactError = false;

        try
        {
            var body =
                $"<p><strong>From:</strong> {contactModel.FirstName} {contactModel.LastName} ({contactModel.Email})</p>" +
                $"<p><strong>Subject:</strong> {contactModel.Subject}</p>" +
                "<hr/>" +
                $"<p>{contactModel.Message.Replace("\n", "<br/>")}</p>";

            await EmailSender.SendEmailAsync("diapodirect@flaubertgroup.com", $"[DiaspoDirect Contact] {contactModel.Subject}", body);
            contactSent = true;
            contactModel = new();
        }
        catch
        {
            contactError = true;
        }
        finally
        {
            contactSubmitting = false;
        }
    }

    private class ContactModel
    {
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public string Email { get; set; } = "";
        public string Subject { get; set; } = "";
        public string Message { get; set; } = "";
    }

    private readonly List<FaqItem> faqs = new()
    {
        new FaqItem(
            "What can I use DiaspoDirect for today?",
            "DiaspoDirect is live for Pharmacy Prescription Billing. Send a prescription to a verified pharmacy in Côte d'Ivoire, pay the exact XOF bill in USD, and your family collects the medication directly. Education, utilities, healthcare, transportation, and other services are on our roadmap and coming soon."),
        new FaqItem(
            "How does payment and currency conversion work?",
            "You pay in USD through Stripe. The pharmacy provides an itemized bill in XOF (West African CFA francs), and DiaspoDirect converts and pays the pharmacy the exact XOF amount directly — your family never handles cash or currency exchange."),
        new FaqItem(
            "Is my payment secure?",
            "Yes. All payments are processed through Stripe, a leading global payment processor, with full encryption and fraud protection. DiaspoDirect never stores your card details."),

@page "/"
@layout PublicLayout
@using DiaspoDirect.Components.Layout
@using Microsoft.AspNetCore.Identity.UI.Services
@inject IEmailSender EmailSender

<PageTitle>DiaspoDirect — Support Your Loved Ones Back Home</PageTitle>

<div class="landing-page">

    <!-- ── Hero ─────────────────────────────────────────────────────── -->
    <section class="hero-section">
        <div class="hero-mobile-banner">
            <img src="/images/landing_bg03.png" alt="Mother and child connecting with family in Abidjan, Côte d'Ivoire" />
        </div>
        <div class="hero-content">
            <div class="hero-badge"><svg class="ci-flag ci-flag-sm" viewBox="0 0 3 2" aria-label="Côte d'Ivoire"><rect width="1" height="2" fill="#F77F00"/><rect x="1" width="1" height="2" fill="#fff"/><rect x="2" width="1" height="2" fill="#009A44"/></svg> Serving the Ivorian Diaspora</div>
            <h1>Support Your Family<br />in Côte d'Ivoire<br />From Anywhere</h1>
            <p>
                DiaspoDirect lets you securely pay for prescriptions,<br />
                school fees, utilities, clinic visits, transportation,<br />
                and other essential services for your loved ones<br />
                in Côte d'Ivoire.
            </p>
            <p>
                Pay in USD while your family receives the exact CFA<br />
                value through trusted local partners.
            </p>
            <div class="hero-actions">
                <a href="/Account/Register" class="btn-primary-cta"><span class="btn-icon">➤</span> Send a Prescription</a>
                <a href="#how-it-works" class="btn-ghost-cta">See how it works <span class="btn-icon">›</span></a>
            </div>

            <div class="hero-trust-badges">
                <span class="trust-badge"><span class="trust-badge-icon">🔒</span> Secure Stripe Payments</span>
                <span class="trust-badge"><span class="trust-badge-icon">✓</span> Trusted Local Partners</span>
                <span class="trust-badge"><span class="trust-badge-icon">⚡</span> Fast Service</span>
                <span class="trust-badge"><span class="trust-badge-icon">💵</span> Transparent Pricing</span>
            </div>

            <div class="service-chips">
                <span class="service-chip available">
                    <span class="service-chip-icon">💊</span>
                    <span class="service-chip-text"><strong>Pharmacy</strong><em>Available Now</em></span>
                </span>
                <span class="service-chip soon">
                    <span class="service-chip-icon">🎓</span>
                    <span class="service-chip-text"><strong>Education</strong><em>Soon</em></span>
                </span>
                <span class="service-chip soon">
                    <span class="service-chip-icon">⚡</span>
                    <span class="service-chip-text"><strong>Utilities</strong><em>Soon</em></span>
                </span>
                <span class="service-chip soon">
                    <span class="service-chip-icon">🏥</span>
                    <span class="service-chip-text"><strong>Healthcare</strong><em>Soon</em></span>
                </span>
                <span class="service-chip soon">
                    <span class="service-chip-icon">🚕</span>
                    <span class="service-chip-text"><strong>Transportation</strong><em>Soon</em></span>
                </span>
                <span class="service-chip soon">
                    <span class="service-chip-icon">💧</span>
                    <span class="service-chip-text"><strong>Water Bills</strong><em>Soon</em></span>
                </span>
            </div>
            <div class="hero-trust-note"><span class="trust-note-icon">🔒</span> Secure USD payments • Local CFA fulfillment</div>
        </div>

        <!-- Hero story card -->
        <div class="hero-visual">
            <div class="story-card">
                <div class="story-card-header">
                    <span class="story-icon">🧾</span>
                    <span class="story-title">Pharmacy Invoice</span>
                    <span class="story-tag"><svg class="ci-flag ci-flag-xs" viewBox="0 0 3 2" aria-label="Côte d'Ivoire"><rect width="1" height="2" fill="#F77F00"/><rect x="1" width="1" height="2" fill="#fff"/><rect x="2" width="1" height="2" fill="#009A44"/></svg> Abidjan</span>
                </div>
                <div class="story-row">
                    <span class="story-label">Recipient</span>
                    <span class="story-value">Kouassi Jean</span>
                </div>
                <div class="story-row">
                    <span class="story-label">Pharmacie</span>
                    <span class="story-value">Pharmacie du Plateau</span>
                </div>

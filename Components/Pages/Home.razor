    </section>

    <!-- ── Stats strip ──────────────────────────────────────────────────── -->
    <section class="stats-strip">
        <div class="stats-inner">
            <div class="stat-item">
                <div class="stat-icon"><svg class="ci-flag ci-flag-lg" viewBox="0 0 3 2" aria-label="Côte d'Ivoire"><rect width="1" height="2" fill="#F77F00"/><rect x="1" width="1" height="2" fill="#fff"/><rect x="2" width="1" height="2" fill="#009A44"/></svg></div>
                <div class="stat-label">Côte d'Ivoire</div>
                <div class="stat-desc">Current service area</div>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <div class="stat-icon">🏥</div>
                <div class="stat-label">Verified Pharmacies</div>
                <div class="stat-desc">Licensed partners across CI</div>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <div class="stat-icon">🧾</div>
                <div class="stat-label">Itemized Bills</div>
                <div class="stat-desc">Exact XOF amount — always</div>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <div class="stat-icon">💳</div>

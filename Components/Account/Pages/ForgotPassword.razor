@page "/Account/ForgotPassword"
@layout DiaspoDirect.Components.Account.Shared.LoginLayout

@using System.ComponentModel.DataAnnotations
@using System.Text
@using System.Text.Encodings.Web
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@using DiaspoDirect.Data

@inject UserManager<ApplicationUser> UserManager
@inject IEmailSender<ApplicationUser> EmailSender
@inject NavigationManager NavigationManager
@inject IdentityRedirectManager RedirectManager

<PageTitle>Reset Password — DiaspoDirect</PageTitle>

<div class="login-page">
    <!-- Left branding panel -->
    <div class="login-brand">
        <div class="login-brand-inner">
            <a href="/" class="login-logo"><img src="/images/logo/dd_logo.png" alt="DiaspoDirect" style="height:64px; background:white; border-radius:10px; padding:5px 10px;" /></a>
            <div class="login-brand-body">
                <h2 class="login-brand-headline">We've got you<br />covered.</h2>
                <p class="login-brand-sub">Forgot your password? No worries — we'll send a secure reset link to your email address so you can get back to supporting your family.</p>
                <div class="login-trust-badges">
                    <div class="login-badge">
                        <span class="login-badge-icon">&#128274;</span>
                        <span>Bank-grade security</span>
                    </div>
                    <div class="login-badge">
                        <span class="login-badge-icon">&#127758;</span>
                        <span>Cross-border payments</span>
                    </div>
                    <div class="login-badge">
                        <span class="login-badge-icon">&#9989;</span>
                        <span>Verified pharmacies</span>
                    </div>
                </div>
            </div>
            <p class="login-brand-footer">
                <a href="/" class="login-back-link">&#8592; Back to Home</a>
            </p>
        </div>
    </div>

    <!-- Right form panel -->
    <div class="login-form-panel">
        <div class="login-form-card">
            <div class="login-form-header">
                <h1 class="login-form-title">Reset your password</h1>
                <p class="login-form-subtitle">Enter your email and we'll send you a reset link</p>
            </div>

            <EditForm Model="Input" FormName="forgot-password" OnValidSubmit="OnValidSubmitAsync" method="post">
                <DataAnnotationsValidator />

                <div class="login-field">
                    <label class="login-label">Email address</label>
                    <div class="login-input-wrap">
                        <span class="login-input-icon">&#9993;</span>
                        <InputText @bind-Value="Input.Email"
                                   class="login-input"
                                   autocomplete="username"
                                   aria-required="true"
                                   placeholder="you@example.com" />
                    </div>
                    <ValidationMessage For="() => Input.Email" class="login-validation" />
                </div>

                <button type="submit" class="login-submit">Send Reset Link</button>
            </EditForm>

            <p class="login-register-link">
                Remember your password?
                <a href="/Account/Login">Sign in</a>
            </p>
        </div>
    </div>
</div>

<style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    .login-page {
        display: flex;
        min-height: 100vh;
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    }

    .login-brand {
        flex: 0 0 42%;
        background: linear-gradient(160deg, #0d1b3e 0%, #1a2f6e 60%, #0d2b5e 100%);
        display: flex;
        align-items: stretch;
        padding: 2.5rem 3rem;
        position: relative;
        overflow: hidden;
    }

    .login-brand::before {
        content: '';
        position: absolute;
        top: -80px; right: -80px;
        width: 320px; height: 320px;
        border-radius: 50%;
        background: rgba(245, 184, 0, 0.08);
    }

    .login-brand::after {
        content: '';
        position: absolute;
        bottom: -60px; left: -60px;
        width: 240px; height: 240px;
        border-radius: 50%;
        background: rgba(245, 184, 0, 0.06);
    }

    .login-brand-inner {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        width: 100%;
        position: relative;
        z-index: 1;
    }

    .login-logo {
        font-size: 1.6rem;
        font-weight: 800;
        color: #f5b800;
        text-decoration: none;
        letter-spacing: -0.5px;
    }

    .login-brand-body {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 3rem 0;
    }

    .login-brand-headline {
        font-size: 2rem;
        font-weight: 700;
        color: #ffffff;
        line-height: 1.3;
        margin-bottom: 1.25rem;
    }

    .login-brand-sub {
        font-size: 1rem;
        color: rgba(255,255,255,0.72);
        line-height: 1.65;
        max-width: 340px;
        margin-bottom: 2.5rem;
    }

    .login-trust-badges {
        display: flex;
        flex-direction: column;
        gap: 0.9rem;
    }

    .login-badge {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: rgba(255,255,255,0.85);
        font-size: 0.92rem;
    }

    .login-badge-icon {
        font-size: 1.1rem;
        width: 2rem;
        height: 2rem;
        background: rgba(245, 184, 0, 0.15);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .login-back-link {
        color: rgba(255,255,255,0.5);
        font-size: 0.875rem;
        text-decoration: none;
        transition: color 0.2s;
    }

    .login-back-link:hover { color: #f5b800; }

    .login-form-panel {
        flex: 1;
        background: #f7f8fc;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1.5rem;
    }

    .login-form-card {
        background: #ffffff;
        border-radius: 16px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.08);
        padding: 2.75rem 2.5rem;
        width: 100%;
        max-width: 420px;
    }

    .login-form-header {
        margin-bottom: 2rem;
    }

    .login-form-title {
        font-size: 1.75rem;
        font-weight: 700;
        color: #0d1b3e;
        margin-bottom: 0.35rem;
    }

    .login-form-subtitle {
        color: #6b7280;
        font-size: 0.925rem;
    }

    .login-field { margin-bottom: 1.25rem; }

    .login-label {
        display: block;
        font-size: 0.875rem;
        font-weight: 600;
        color: #374151;
        margin-bottom: 0.45rem;
    }

    .login-input-wrap {
        position: relative;
        display: flex;
        align-items: center;
    }

    .login-input-icon {
        position: absolute;
        left: 0.875rem;
        font-size: 1rem;
        color: #9ca3af;
        pointer-events: none;
        line-height: 1;
    }

    .login-input {
        width: 100%;
        padding: 0.75rem 0.875rem 0.75rem 2.5rem;
        border: 1.5px solid #d1d5db;
        border-radius: 8px;
        font-size: 0.95rem;
        color: #111827;
        background: #fff;
        transition: border-color 0.2s, box-shadow 0.2s;
        outline: none;
    }

    .login-input:focus {
        border-color: #1a2f6e;
        box-shadow: 0 0 0 3px rgba(26, 47, 110, 0.12);
    }

    .login-input::placeholder { color: #9ca3af; }

    .login-validation {
        display: block;
        color: #b91c1c;
        font-size: 0.8rem;
        margin-top: 0.35rem;
    }

    .login-submit {
        width: 100%;
        padding: 0.85rem;
        background: #f5b800;
        color: #0d1b3e;
        font-size: 1rem;
        font-weight: 700;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        transition: background 0.2s, transform 0.1s, box-shadow 0.2s;
        letter-spacing: 0.01em;
    }

    .login-submit:hover {
        background: #e0a800;
        box-shadow: 0 4px 12px rgba(245,184,0,0.35);
    }

    .login-submit:active { transform: translateY(1px); }

    .login-register-link {
        text-align: center;
        margin-top: 1.5rem;
        font-size: 0.875rem;
        color: #6b7280;
    }

    .login-register-link a {
        color: #1a2f6e;
        font-weight: 600;
        text-decoration: none;
    }

    .login-register-link a:hover { text-decoration: underline; }

    @@media (max-width: 768px) {
        .login-brand { display: none; }
        .login-form-panel { background: #0d1b3e; }
        .login-form-card { box-shadow: 0 8px 32px rgba(0,0,0,0.25); }
    }
</style>

@code {
    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    private async Task OnValidSubmitAsync()
    {
        var user = await UserManager.FindByEmailAsync(Input.Email);
        if (user is null || !(await UserManager.IsEmailConfirmedAsync(user)))
        {
            RedirectManager.RedirectTo("Account/ForgotPasswordConfirmation");
        }

        var code = await UserManager.GeneratePasswordResetTokenAsync(user);
        code = WebEncoders.Base64UrlEncode(Encoding.UTF8.GetBytes(code));
        var callbackUrl = NavigationManager.GetUriWithQueryParameters(
            NavigationManager.ToAbsoluteUri("Account/ResetPassword").AbsoluteUri,
            new Dictionary<string, object?> { ["code"] = code });

        await EmailSender.SendPasswordResetLinkAsync(user, Input.Email, HtmlEncoder.Default.Encode(callbackUrl));

        RedirectManager.RedirectTo("Account/ForgotPasswordConfirmation");
    }

    private sealed class InputModel
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = "";
    }
}
